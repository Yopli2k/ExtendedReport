{% extends "Master/MenuBghTemplate.html.twig" %}

{% set pageData = fsc.getPageData() %}

{% block bodyHeaderOptions %}
    {{ parent() }}
    <div class="container-fluid mb-3 d-print-none">
        <div class="row">
            <div class="col-12 text-end">
                <h1 class="h4 mb-0 d-none d-md-inline-block">
                    {% set title = trans(fsc.getPageData()['title']) | capitalize %}
                    {{ title }}<i class="{{ fsc.getPageData()['icon'] }} ms-3" aria-hidden="true"></i>
                </h1>
            </div>
        </div>
    </div>
{% endblock %}

{% block body %}
    {{ parent() }}

    <script>
        function printAction(value) {
            const form = document.getElementById("formReportTest");
            form.querySelector('input[name="action"]').value = value;
            form.target = "_blank";
            form.submit();
        }
    </script>
    <form id="formReportTest" method="post">
        <input type="hidden" name="action" value="" />
        <div class="container-fluid">
            <div class="card border-primary shadow mb-3">
                <div class="card-body text-center">
                    <div class="dropdown d-inline-block">
                        <button class="btn btn-lg btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-solid fa-flask fa-fw" aria-hidden="true"></i>
                            <span class="d-none d-sm-inline-block">{{ trans('report-test') }}</span>
                        </button>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" href="#" onclick="printAction('print-test');">
                                    <i class="fa-solid fa-print fa-fw" aria-hidden="true"></i> {{ trans('print-test') }}
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#" onclick="printAction('portrait-test');">
                                    <i class="fa-solid fa-print fa-fw" aria-hidden="true"></i> {{ trans('portrait-test') }}
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#" onclick="printAction('landscape-test');">
                                    <i class="fa-solid fa-print fa-fw" aria-hidden="true"></i> {{ trans('landscape-test') }}
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="#" onclick="printAction('html-test');">
                                    <i class="fa-solid fa-table fa-fw" aria-hidden="true"></i> {{ trans('html-test') }}
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#" onclick="printAction('html-grouped-test');">
                                    <i class="fa-solid fa-layer-group fa-fw" aria-hidden="true"></i> {{ trans('html-grouped-test') }}
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#" onclick="printAction('html-multiline-test');">
                                    <i class="fa-solid fa-bars-staggered fa-fw" aria-hidden="true"></i> {{ trans('html-multiline-test') }}
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </form>
{% endblock %}
