{% extends "Master/MicroTemplate.html.twig" %}

{% block body %}
    {% set detailUrl = fsc.detailClickUrl|default('') %}
    {% set printUrl = fsc.printUrl|default('') %}
    <div class="container-fluid py-3">
        <div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
            <h1 class="h4 mb-0">{{ trans(fsc.title) | capitalize }}</h1>
            {% if printUrl %}
                <button type="button" class="btn btn-primary" onclick="window.open('{{ printUrl|e('js') }}', '_blank');">
                    <i class="fa-solid fa-print fa-fw" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline-block">{{ trans('print') }}</span>
                </button>
            {% else %}
                <button type="button" class="btn btn-primary" onclick="window.print();">
                    <i class="fa-solid fa-print fa-fw" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline-block">{{ trans('print') }}</span>
                </button>
            {% endif %}
        </div>
        {{ fsc.reportHtml | raw }}
    </div>
    {% if detailUrl %}
        {% include 'Block/ReportDetailModal.html.twig' with {
            'fsc': fsc,
            'detailUrl': detailUrl
        } %}
    {% endif %}
{% endblock %}
