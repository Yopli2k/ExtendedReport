<report>
    <config>
        <page type="A4" orientation="landscape" />
        <font type="Arial" size="12" />
        <default group="main" alter="other" />
    </config>

    <group name="main">
        <header height="60">
            <!-- Titulo -->
            <column posx="20" posy="15" width="500" hideonview="true">
                <widget type="label" value="report-test" translate="true" align="center" bold="true" size="16" />
            </column>

            <!-- Etiquetas de columna -->
            <column posx="20" posy="40" width="160">
                <widget type="label" value="description" translate="true" bold="true" />
            </column>
            <column posx="180" posy="40" width="80">
                <widget type="label" value="P1" align="right" bold="true" bgcolor="EBEDEF" />
            </column>
            <column posx="260" posy="40" width="80">
                <widget type="label" value="P2" align="right" bold="true" bgcolor="EBEDEF" />
            </column>
            <column posx="340" posy="40" width="80">
                <widget type="label" value="P3" align="right" bold="true" bgcolor="EBEDEF" />
            </column>
            <column posx="420" posy="40" width="80">
                <widget type="label" value="total" translate="true" align="right" bold="true" bgcolor="EBEDEF" />
            </column>
        </header>

        <!-- DETAIL multilínea: 3 subfilas (actual / anterior / diferencia) por registro -->
        <detail height="54" subrows="3">
            <!-- Identidad: nombre y código apilados -->
            <column posx="20" posy="0" width="160">
                <widget type="label" fieldname="name" bold="true" />
            </column>
            <column posx="20" posy="20" width="160">
                <widget type="label" fieldname="code" italic="true" />
            </column>

            <!-- Rótulos de subfila -->
            <column posx="150" posy="0" width="28">
                <widget type="label" value="Act" align="left" bold="true" />
            </column>
            <column posx="150" posy="20" width="28">
                <widget type="label" value="Ant" align="left" bold="true" />
            </column>
            <column posx="150" posy="40" width="28">
                <widget type="label" value="Dif" align="left" bold="true" />
            </column>

            <!-- Periodo 1 -->
            <column posx="180" posy="0" width="80"><widget type="number" fieldname="current[1]" /></column>
            <column posx="180" posy="20" width="80"><widget type="number" fieldname="previous[1]" /></column>
            <column posx="180" posy="40" width="80"><widget type="number" fieldname="difference[1]" negative="red" /></column>

            <!-- Periodo 2 -->
            <column posx="260" posy="0" width="80"><widget type="number" fieldname="current[2]" /></column>
            <column posx="260" posy="20" width="80"><widget type="number" fieldname="previous[2]" /></column>
            <column posx="260" posy="40" width="80"><widget type="number" fieldname="difference[2]" negative="red" /></column>

            <!-- Periodo 3 -->
            <column posx="340" posy="0" width="80"><widget type="number" fieldname="current[3]" /></column>
            <column posx="340" posy="20" width="80"><widget type="number" fieldname="previous[3]" /></column>
            <column posx="340" posy="40" width="80"><widget type="number" fieldname="difference[3]" negative="red" /></column>

            <!-- Total -->
            <column posx="420" posy="0" width="80"><widget type="number" fieldname="current[0]" bold="true" /></column>
            <column posx="420" posy="20" width="80"><widget type="number" fieldname="previous[0]" bold="true" /></column>
            <column posx="420" posy="40" width="80"><widget type="number" fieldname="difference[0]" bold="true" negative="red" /></column>
        </detail>

        <!-- FOOTER multilínea: sumas por periodo (actual / anterior / diferencia) -->
        <footer height="54">
            <column posx="20" posy="0" width="120">
                <widget type="label" value="total" translate="true" align="right" bold="true" />
            </column>

            <column posx="150" posy="0" width="28"><widget type="label" value="Act" align="left" bold="true" /></column>
            <column posx="150" posy="20" width="28"><widget type="label" value="Ant" align="left" bold="true" /></column>
            <column posx="150" posy="40" width="28"><widget type="label" value="Dif" align="left" bold="true" /></column>

            <column posx="180" posy="0" width="80"><widget type="calculated" operator="sum" fieldname="current[1]" bold="true" /></column>
            <column posx="180" posy="20" width="80"><widget type="calculated" operator="sum" fieldname="previous[1]" bold="true" /></column>
            <column posx="180" posy="40" width="80"><widget type="calculated" operator="sum" fieldname="difference[1]" bold="true" /></column>

            <column posx="260" posy="0" width="80"><widget type="calculated" operator="sum" fieldname="current[2]" bold="true" /></column>
            <column posx="260" posy="20" width="80"><widget type="calculated" operator="sum" fieldname="previous[2]" bold="true" /></column>
            <column posx="260" posy="40" width="80"><widget type="calculated" operator="sum" fieldname="difference[2]" bold="true" /></column>

            <column posx="340" posy="0" width="80"><widget type="calculated" operator="sum" fieldname="current[3]" bold="true" /></column>
            <column posx="340" posy="20" width="80"><widget type="calculated" operator="sum" fieldname="previous[3]" bold="true" /></column>
            <column posx="340" posy="40" width="80"><widget type="calculated" operator="sum" fieldname="difference[3]" bold="true" /></column>

            <column posx="420" posy="0" width="80"><widget type="calculated" operator="sum" fieldname="current[0]" bold="true" /></column>
            <column posx="420" posy="20" width="80"><widget type="calculated" operator="sum" fieldname="previous[0]" bold="true" /></column>
            <column posx="420" posy="40" width="80"><widget type="calculated" operator="sum" fieldname="difference[0]" bold="true" /></column>
        </footer>
    </group>
</report>
